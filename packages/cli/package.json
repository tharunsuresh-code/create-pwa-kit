{
  "name": "create-pwa-kit",
  "version": "0.1.1",
  "description": "Scaffold a production-ready Next.js 14 PWA in seconds",
  "license": "MIT",
  "homepage": "https://github.com/tharunsuresh-code/create-pwa-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/tharunsuresh-code/create-pwa-kit.git"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "create-pwa-kit": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean && rm -rf dist/template && cp -r ../template dist/template",
    "dev": "tsup src/index.ts --format cjs --watch"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}
